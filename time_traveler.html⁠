<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Quantum Time Traveler</title>
    <style>
        body { 
            background: #000; 
            color: #0f0; 
            font-family: 'Courier New', Courier, monospace; 
            text-align: center; 
            padding: 50px; 
        }
        input { 
            background: #111; 
            color: #0f0; 
            border: 1px solid #0f0; 
            padding: 10px; 
            text-align: center; 
            width: 200px; 
        }
        button { 
            background: #0f0; 
            color: #000; 
            border: none; 
            padding: 10px 20px; 
            cursor: pointer; 
            font-weight: bold; 
        }
        #status { 
            margin-top: 20px; 
            font-size: 1.2em; 
        }
    </style>
</head>
<body>
    <h1>QUANTUM TIME TRAVELER</h1>
    <p>Target destination: [Future] (in minutes)</p>
    
    <input type="number" id="minutesInput" placeholder="Minutes to jump">
    <button onclick="startQuantumJump()">INITIATE JUMP</button>
    
    <div id="status">System Status: Standby</div>

    <script>
        function startQuantumJump() {
            let minutes = document.getElementById('minutesInput').value;
            
            if (!minutes || minutes <= 0) {
                alert("Please enter a valid time value.");
                return;
              }
            
            let totalSeconds = minutes * 60;
            let displayElement = document.getElementById('status');
            
            displayElement.innerText = "Calibrating quantum coordinates...";
            
            setTimeout(() => {
                let countdownTimer = setInterval(() => {
                    totalSeconds--;
                    let minutesLeft = Math.floor(totalSeconds / 60);
                    let secondsLeft = totalSeconds % 60;
                    
                    displayElement.innerText = `Traversing time-stream... ETA: ${minutesLeft}m ${secondsLeft}s`;
                    
                    if (totalSeconds <= 0) {
                        clearInterval(countdownTimer);
                        displayElement.innerText = "SUCCESS: You have arrived in the future.";
                        alert("Quantum jump successful. Welcome to the future.");
                    }
                }, 1000);
            }, 2000);
        }
    </script>
</body>
</html>
